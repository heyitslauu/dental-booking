generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics Clinic[]
}

model Clinic {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String   @unique
  address        String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinicServices ClinicService[]
  clinicStaff    ClinicStaff[]
  appointments   Appointment[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         UserRole @default(PATIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientProfile PatientProfile?
  staffProfile   StaffProfile?
}

model StaffProfile {
  id        String   @id @default(cuid())
  userId    String?  @unique
  firstName String
  lastName  String
  title     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinicStaff  ClinicStaff[]
  appointments Appointment[]
}

model ClinicStaff {
  id             String   @id @default(cuid())
  clinicId       String
  staffProfileId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([clinicId, staffProfileId])
  @@index([staffProfileId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinicServices ClinicService[]
  appointments   Appointment[]
}

model ClinicService {
  id              String   @id @default(cuid())
  clinicId        String
  serviceId       String
  priceCents      Int
  durationMinutes Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([clinicId, serviceId])
  @@index([serviceId])
}

model PatientProfile {
  id        String   @id @default(cuid())
  userId    String?  @unique
  firstName String
  lastName  String
  email     String?
  phone     String?
  birthDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments Appointment[]
}

model Appointment {
  id               String            @id @default(cuid())
  referenceNumber  String            @unique
  clinicId         String
  serviceId        String
  patientProfileId String
  staffProfileId   String?
  startAt          DateTime
  endAt            DateTime
  status           AppointmentStatus @default(PENDING)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  clinic         Clinic         @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Restrict)
  staffProfile   StaffProfile?  @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)

  @@index([clinicId, startAt])
  @@index([status])
  @@index([patientProfileId])
  @@index([staffProfileId])
}
